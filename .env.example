# =============================================================================
# KlebNET-GSP environment template
# Copy to .env and fill in real values. NEVER commit a populated .env.
# =============================================================================

# Frontend → backend URL (used by React client)
REACT_APP_API_URL=http://localhost:8080/api/

# =============================================================================
# MongoDB connection
# =============================================================================
# Local mongod:
MONGODB_URI=mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017

# Or, point at remote (Atlas / EC2 via SSH tunnel):
#   MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/?retryWrites=true&w=majority
#   MONGODB_URI=mongodb://<user>:<pass>@localhost:27018/?directConnection=true   # tunnel

# Database name override for the kpneumo collection.
# Default mapping in routes/api/api.js: dbName='kpneumo' / collection='amrnetdb_kpneumo'
MONGO_DBNAME_KPNEUMO=kpneumo

# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
PORT=8080
